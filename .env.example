# Archivo de configuración - Copia este archivo a .env y completa con tus credenciales

# YouTube API Key
# Obtén tu API Key en: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=tu_api_key_aqui

# IDs de tus canales de YouTube (separados por coma si tienes varios)
# Para obtener el ID: Ve a tu canal -> Clic derecho -> Ver código fuente -> Busca "channelId"
YOUTUBE_CHANNEL_IDS=UCxxxxxxxxxxxxxxxxx,UCyyyyyyyyyyyyyyyy

# Anthropic API Key para análisis con IA
# Obtén tu API Key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_anthropic_api_key_aqui

# Configuración de análisis
DAYS_TO_ANALYZE=90
MIN_VIDEOS_FOR_ANALYSIS=10
MAX_VIDEOS_PER_CHANNEL=200

# Scheduler — ejecución automática diaria (usado por scheduler.py)
SCHEDULE_HOUR=15
SCHEDULE_MINUTE=0
SCHEDULE_TIMEZONE=America/Panama

# Telegram — notificaciones automáticas (opcional)
# Crear bot: https://t.me/BotFather → /newbot
# Obtener chat_id: envía un mensaje al bot, luego visita https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Integrations — Calendar + Sheets export (opcional)
# Requiere habilitar "Google Calendar API" y "Google Sheets API" en Google Cloud Console.
# El token se genera automáticamente al primer uso (abre navegador para autorizar).
GOOGLE_INTEGRATIONS_TOKEN_FILE=token_integrations.json

# Revenue — estimador de ingresos (Mejora 16.x)
# CPM estimado en USD (valor promedio para tu nicho). Ajusta según tu región/industria.
ESTIMATED_CPM=4.50

# Logging — nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Base de datos MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=youtube_analytics
